[Unit]
Description=Gunicorn for DBWE E-Fahrzeuge Platform
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/dbwe_emobility
Environment="PATH=/opt/dbwe_emobility/.venv/bin"
EnvironmentFile=/opt/dbwe_emobility/.env
ExecStart=/opt/dbwe_emobility/.venv/bin/gunicorn -b 127.0.0.1:8000 run:app
Restart=always

[Install]
WantedBy=multi-user.target
